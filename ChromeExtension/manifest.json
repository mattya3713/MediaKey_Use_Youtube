{
  "manifest_version": 3,
  "name": "YouTube Media Key Remote",
  "version": "1.0.0",
  "description": "WebSocket経由でYouTube動画を操作します。",
  "permissions": ["tabs", "scripting", "alarms"],
  "host_permissions": ["*://youtube.com/*", "*://*.youtube.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://youtube.com/*", "*://*.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
